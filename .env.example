POSTGRES_DB=world_cup_insights
# Local demo defaults only. Override these for any shared deploy.
POSTGRES_USER=worldcup_local
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_PORT=127.0.0.1:5432
REDIS_PORT=127.0.0.1:6379
DATABASE_URL=postgresql+psycopg://worldcup_local:change-me-local-only@postgres:5432/world_cup_insights
REDIS_URL=redis://redis:6379/0
API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LIVE_DATA_PROVIDER=seeded
LIVE_POLL_INTERVAL_SECONDS=1800
SCHEDULE_POLL_INTERVAL_SECONDS=21600
MODEL_VERSION=wc-v0.2-norway
ALLOWED_BROADCASTER_HOSTS=nrk.no,tv.nrk.no,tv2.no,play.tv2.no
EXTERNAL_DATA_CACHE_DIR=data/raw
EXTERNAL_DATA_CACHE_TTL_SECONDS=300
EXTERNAL_REQUEST_TIMEOUT_SECONDS=15
# Nøkkelfri CC0-snapshot. Kan overstyres med en kompatibel JSON-kilde.
FIFA_SCHEDULE_URL=https://raw.githubusercontent.com/openfootball/worldcup.json/master/2026/worldcup.json
FIFA_RANKINGS_URL=
WORLD_FOOTBALL_ELO_URL=
WORLD_BANK_BASE_URL=https://api.worldbank.org/v2
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_KEY=
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026
